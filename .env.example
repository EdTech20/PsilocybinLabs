# Copy to `.env` and fill in. DO NOT commit the real .env.

PORT=3000

# --- Issuer signatory (1210954 B.C. Ltd.) ---
ISSUER_SIGNER_NAME="Ian McDonald"
ISSUER_SIGNER_EMAIL="ian@northwardcap.com"

# --- DocuSign JWT grant (demo env shown) ---
# Leave these blank to run in "download-only" mode.
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_USER_ID=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_AUTH_SERVER=account-d.docusign.com
DOCUSIGN_BASE_PATH=https://demo.docusign.net/restapi

# Paste the RSA private key as a single line with \n for line breaks, e.g.:
# DOCUSIGN_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEpAIB...\n-----END RSA PRIVATE KEY-----"
DOCUSIGN_PRIVATE_KEY=
